// DistressHub — Postgres production schema variant.
//
// To switch from the in-memory store to real Postgres:
//   1. Copy this file over prisma/schema.prisma
//   2. Provision a Neon (or Vercel Postgres) DB and put DATABASE_URL in .env.local + Vercel env
//   3. Run `npx prisma migrate dev --name init`
//   4. In lib/db.ts, replace `export { store as prisma } from "./store"` with
//      `import { PrismaClient } from "@prisma/client"; export const prisma = new PrismaClient()`
//   5. Run `npx tsx prisma/seed.ts` to load seed/listings.json into Postgres
//   6. Smoke test all routes — the API surface of the in-memory store matches Prisma's, so no
//      route handlers should need changes
//
// The only delta from prisma/schema.prisma is:
//   - provider: "sqlite" → "postgresql"
//   - datasource adds `url = env("DATABASE_URL")` (Prisma 7 wants URL in schema for Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id          String  @id @default(cuid())
  externalId  String  @unique
  source      String  @default("BAANKNET")

  title       String
  description String?
  propertyType String
  bank        String

  address  String
  city     String
  state    String
  pincode  String?
  latitude  Float?
  longitude Float?

  reservePrice Float
  emdAmount    Float?
  estimatedFmv Float?
  discountPct  Float?

  builtUpArea Float?
  carpetArea  Float?
  bedrooms    Int?

  auctionDate    DateTime?
  possessionType String?
  auctionStatus  String   @default("UPCOMING")

  dhScore      Int?
  scoreSignals String?

  pipelineStage String  @default("INGESTED")
  notes         String?

  imageUrls String  @default("[]")
  sourceUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  interests InvestorInterest[]

  @@index([city, propertyType])
  @@index([dhScore])
  @@index([auctionDate])
  @@index([pipelineStage])
  @@index([source])
}

model Investor {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  phone      String?
  type       String
  ticketSize Float?
  notes      String?
  createdAt  DateTime @default(now())

  interests InvestorInterest[]
}

model InvestorInterest {
  id         String   @id @default(cuid())
  propertyId String
  investorId String
  message    String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([investorId])
}

model IngestRun {
  id              String   @id @default(cuid())
  source          String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  status          String
  listingsTotal   Int      @default(0)
  listingsAdded   Int      @default(0)
  listingsUpdated Int      @default(0)
  errorMessage    String?

  @@index([source, startedAt])
}
