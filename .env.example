# DistressHub — copy to .env.local and fill in values

# Supabase Postgres (Mumbai). Both URLs use the pooler — Supabase direct is IPv6-only.
# DATABASE_URL = transaction pooler (port 6543) — for app runtime
# DIRECT_URL = session pooler (port 5432) — for Prisma Migrate
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres"

# Env-gated demo auth password — gates /dashboard, /pipeline, /admin (proxy.ts)
# and the operator-only mutation routes (/api/properties/[id]/stage, /api/scraper/trigger).
# REQUIRED: there is no hardcoded fallback — if unset, the gate fails closed
# (no login succeeds). The session cookie stores a SHA-256 token of this value,
# not the password itself (see lib/auth-token.ts).
DEMO_PASSWORD="distress2026"

# HMAC secret for scraper → /api/ingest. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
INGEST_SECRET="replace-with-random-64-hex"

# Anthropic API key for AI-generated investor memo PDFs.
# Get from https://console.anthropic.com/settings/keys (sk-ant-...).
# Memo PDF still renders without it — narrative falls back to a heuristic.
ANTHROPIC_API_KEY=""

# Lead notifications — email the team when someone submits Express Interest.
# All optional: if RESEND_API_KEY or LEAD_NOTIFY_EMAIL is unset, the lead is
# still saved to the DB and the email is simply skipped (logged warning).
#   RESEND_API_KEY    — re_... from https://resend.com/api-keys
#   LEAD_NOTIFY_EMAIL — inbox that receives new-lead alerts
#   RESEND_FROM       — verified sender; defaults to "DistressHub <onboarding@resend.dev>"
#                       (resend.dev only delivers to your own Resend account email —
#                        set a verified-domain sender for real delivery).
RESEND_API_KEY=""
LEAD_NOTIFY_EMAIL=""
RESEND_FROM=""

# Public — name + target listing count shown in the hero
NEXT_PUBLIC_APP_NAME="Distress Hub"
NEXT_PUBLIC_TARGET_LISTING_COUNT="412"
