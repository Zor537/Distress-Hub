{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/scrape-baanknet",
      "schedule": "30 4 * * *"
    }
  ],
  "functions": {
    "app/api/cron/scrape-baanknet/route.ts": {
      "maxDuration": 60
    },
    "app/api/ingest/route.ts": {
      "maxDuration": 30
    }
  }
}
